## One-way Repeated Measures ANOVA Function: "onewayrepeatedanova()"

This function automatically merges pre, post, and post2 data sets, runs the One-way repeated measures ANOVA with assumptions check, and then exports outputs for you all at once. Please make sure to name data files accurately (i.e., “data_treat_pre.csv”, “data_treat_post.csv”, and “data_treat_post2.csv”) and have them saved in the working directory. 

```{r, results='hide', message=FALSE, warning=FALSE}
# You can copy and past the following function in the console panel of RStudio: onewayrepeatedanova()
```

```{r, message=FALSE, warning=FALSE, echo=FALSE}
  # Read all data sets
  data_treat_pre <- read_csv("data_treat_pre.csv", show_col_types = FALSE)
  data_treat_post<- read_csv("data_treat_post.csv", show_col_types = FALSE)
  data_treat_post2 <- read_csv("data_treat_post2.csv", show_col_types = FALSE)

  # Replace skipped answers with "0"
  data_treat_pre[is.na(data_treat_pre)]= 0
  data_treat_post[is.na(data_treat_post)]= 0
  data_treat_post2[is.na(data_treat_post2)]= 0

  # Change column names with their origin'sir
  colnames(data_treat_pre) <- paste(colnames(data_treat_pre), "pre", sep = "_")
  colnames(data_treat_post) <- paste(colnames(data_treat_post), "post", sep = "_")
  colnames(data_treat_post2) <- paste(colnames(data_treat_post2), "post2", sep = "_")

  # Calculate average scores
  data_treat_pre <- data_treat_pre %>% mutate(avg_score_pre = round(rowMeans(data_treat_pre[,-1]),3))
  data_treat_post <- data_treat_post %>% mutate(avg_score_post = round(rowMeans(data_treat_post[,-1]),3))
  data_treat_post2 <- data_treat_post2 %>% mutate(avg_score_post2 = round(rowMeans(data_treat_post2[,-1]),3))

  # Merge pre/post/post2 data
  data_treat_prepost<-merge(data_treat_pre, data_treat_post, by.x = "id_pre",  by.y = "id_post")
  treat_data_merged<-merge(data_treat_prepost, data_treat_post2, by.x = "id_pre",  by.y = "id_post2")
  names(treat_data_merged)[names(treat_data_merged) == 'id_pre'] <- "id"

  multmodel <- lm(cbind(treat_data_merged$avg_score_pre, treat_data_merged$avg_score_post, treat_data_merged$avg_score_post2)~1)
  Interventions <- factor(c("avg_score_pre", "avg_score_post", "avg_score_post2"), ordered=F)
  model1 <- Anova(multmodel, idata=data.frame(Interventions),idesign=~Interventions, type="III")

  result <- summary(model1, multivariate=F)

  avg_score_df <- as.data.frame(cbind(treat_data_merged$avg_score_pre, treat_data_merged$avg_score_post, treat_data_merged$avg_score_post2))
  names(avg_score_df) <- c("pre", "post", "post2")

  df_Long <- gather(avg_score_df, key="Time", value="Score")
  post_hoc <- aov(Score~Time, data=df_Long)
  pwc <- TukeyHSD(post_hoc)

  # Check normality of Residuals
  shapirotest <- shapiro.test(resid(post_hoc))

  # Check homogeneity of variances
  levene_result <- leveneTest(df_Long$Score, df_Long$Time)

  avg_score_df_fried <- cbind(treat_data_merged$avg_score_pre, treat_data_merged$avg_score_post, treat_data_merged$avg_score_post2)
  df_Long_fried <- melt(avg_score_df_fried)
  names(df_Long_fried) <- c("id", "Time", "Score")
  # Name Time(group) -> 1=Pre, 2=Post, 3=Post2
  df_Long_fried$Time <- factor(df_Long_fried$Time,levels=c(1,2,3),labels=c("Pre", "Post", "Post2"))

  descriptive <- df_Long_fried %>%
    group_by(Time) %>%
    get_summary_stats(Score, type="common")

  # means <- c(mean(treat_data_merged$avg_score_pre),mean(treat_data_merged$avg_score_post),mean(treat_data_merged$avg_score_post2))
  # plot(x=means, type="l", ylab="Average Score", xlab="Time", main="One-way Repeated Measures ANOVA")

  friedman_result <- friedman.test(avg_score_df_fried)

  friedman_pwc <- df_Long_fried %>%
    wilcox_test(Score~Time, paired=TRUE, p.adjust.method="bonferroni")
```
```{r, message=FALSE, warning=FALSE, echo=FALSE}
  # Print the results
  print("Results of Testing Assumptions")
  print("Normality of Residuals:")
  print(shapirotest)
  print("Please refer to the histogram and the normal Q-Q plot in the 'Plots' panel to visually inspect the normality of residuals.")
    hist(post_hoc$residuals)
    qqnorm(post_hoc$residuals)
  print("Homogeneity of Variances:")
  print(levene_result)
  print("Descriptive Statistics: Average Scores")
  print(descriptive)
    ggboxplot(df_Long_fried, x="Time", y="Score", add="jitter")
  print("Result of the main One-way Repeated Measures ANOVA")
  print(result)
  print("Pairwise Comparisons")
  print(pwc)
  if (shapirotest$p.value < 0.05) {
    print("Since the p-value of the Shapiro-Wilk test is less than 0.05, you need to use the Friedman test results presented below")
  } else {
    print("It is safe to use the results above since the p-value of the Shapiro-Wilk test is greater than 0.05. The Friedman results below confirm/complement the results above.")
  }
  print("Friedman Rank Sum Test - Result and Pairwise Comparisons")
  print(friedman_result)
  print(friedman_pwc)
```

## Analysis of Demographic Group Differences Function: "demogroupdiff(csv_data)"

The 'demogroupdiff()' function requires users to type a data file name as shown in the sample code below. You can input any of the data file names (i.e., "data_treat_pre.csv", "data_treat_post.csv", or "data_treat_post2.csv") as they become available for the analysis of demographic group differences. This function automatically combines demographic variables to a data set, runs the analysis of variance (ANOVA) with assumptions check to examine demographic sub-group differences, and then exports outputs for you all at once. You should have both test data ("data_treat_pre.csv", "data_treat_post.csv", or "data_treat_post2.csv") and demographic data ("demographic_data.csv") files in the working directory; please make sure to name data files accurately and have them saved in the working directory. 

```{r, message=FALSE, warning=FALSE}
# You can copy and paste the following function into the console panel of RStudio: demogroupdiff("data_treat_pre.csv"), demogroupdiff("data_treat_post.csv"), or demogroupdiff("data_treat_post2.csv")
```

```{r, message=FALSE, warning=FALSE, echo=FALSE}
  # Reading
    data_original <- read_csv("data_treat_pre.csv",col_types = cols())
    demographic_data <- read_csv("demographic_data.csv", show_col_types = FALSE)

  # Replace skipped answers with "0"
  data_original[is.na(data_original)]= 0

  # Calculate average scores
  data_original <- data_original %>% mutate(avg_score = round(rowMeans(data_original[,-1]),3))

  # Merge test data and demographic data
  data_original <- merge(data_original, demographic_data, by.x = "id",  by.y = "id")

  # Take demographic variable name and create a subset of the dataframe with average score and demographic data
  # group_name <- readline(prompt="Enter demographic variable name: ")
  data_original <- select(data_original, c('avg_score', 'grade'))
  names(data_original) <- c("average_score", "group")

  # Descriptive statistics
  descriptive <- group_by(data_original, group) %>%
    summarise(
      count = n(),
      mean = mean(average_score, na.rm = TRUE),
      sd = sd(average_score, na.rm = TRUE)
    )

  # Conduct sub-group comparisons
  one_way <- aov(average_score ~ factor(group), data=data_original)
  pwc <- TukeyHSD(one_way)

  # Check normality of residuals
  shapirotest <- shapiro.test(resid(one_way))

  # Check homogeneity of variances
  levene_result <- leveneTest(average_score ~ factor(group), data=data_original)

  ## Kruskal-Wallis Test: Non-parametric version of one-way ANOVA
  np_one_way <- kruskal.test(average_score ~ group, data=data_original)
  np_pwc <- pairwise.wilcox.test(data_original$average_score, data_original$group,
                       p.adjust.method = "BH")

  # Print the results
  print("Results of Testing Assumptions")
  print("Normality of Residuals:")
  print(shapirotest)
    hist(one_way$residuals)
    qqnorm(one_way$residuals)
  print("Homogeneity of Variances:")
  print(levene_result)
  print("Results of One-way ANOVA: Group Difference(s) (Parametric)")
  print(summary(one_way))
  print("Pairwide Comparisons")
  print(descriptive)
  print(pwc)
  if (shapirotest$p.value < 0.05) {
    print("Since the p-value of the Shapiro-Wilk test is less than 0.05, you need to use the Kruskal-Wallis test results presented below")
  } else {
    print("It is safe to use the results above since the p-value of the Shapiro-Wilk test is greater than 0.05. The Kruskal-Wallis test results below confirm/complement the results above.")
  }
  print("Results of Kruskal_Wallis Test (Non-parametric)")
  print(np_one_way)
  print(np_pwc)
```
